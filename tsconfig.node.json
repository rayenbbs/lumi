{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "out/main",
    "baseUrl": ".",
    "paths": {}
  },
  "include": [
    "electron.vite.config.*",
    "electron/**/*"
  ]
}
